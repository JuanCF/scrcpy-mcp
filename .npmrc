# =============================================================================
# NPM Security Configuration — Supply Chain Attack Mitigation
# =============================================================================

# CRITICAL: Disable automatic execution of lifecycle scripts (postinstall,
# preinstall, prepare, etc.). This blocks the primary attack vector where
# compromised packages run malicious code during installation.
#
# KNOWN IMPACTS for this project:
#   • esbuild (used by tsup) won't download its platform binary during install.
#     After installing, explicitly rebuild trusted packages:
#       npm rebuild esbuild --ignore-scripts=false
#   • ffmpeg-static (optional) won't download its binary during install.
#     After installing, run:
#       npm rebuild ffmpeg-static --ignore-scripts=false
#   • npm publish will skip the prepublishOnly hook.
#     When publishing, run:
#       npm publish --ignore-scripts=false
#
# If this is too disruptive for daily development, you can comment this out
# and instead run: npm install --ignore-scripts
ignore-scripts=true

# Strict engine compatibility checks (Node.js version, etc.)
engine-strict=true

# Always generate and respect package-lock.json for reproducible installs
package-lock=true

# Save exact versions (no ^ or ~ ranges) when adding new dependencies.
# Prevents automatic resolution to newer, potentially compromised versions.
save-exact=true

# Strict SSL certificate validation when contacting the registry
strict-ssl=true

# Pin to the official npm registry
registry=https://registry.npmjs.org/

# Run security audit automatically after every install
audit=true

# Minimum vulnerability level that causes audit to fail / exit non-zero
audit-level=moderate
